{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  description: 'Group linters, test runners, and Node.js related packages.',
  extends: [
    'group:linters',
    'group:test',
    'group:nodeJs',
  ],
  packageRules: [
    {
      description: 'Group all @types/* devDependencies (excluding @types/node which follows Node LTS).',
      matchManagers: ['npm'],
      matchDepTypes: ['devDependencies'],
      matchPackageNames: ['@types/*', '!@types/node'],
      matchUpdateTypes: ['minor', 'patch'],
      groupName: '@types',
    },
  ],
}
